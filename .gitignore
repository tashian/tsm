# Binaries built at repo root (the !/tsmd/ negation keeps the Swift source
# directory tracked — `/tsmd` alone would also match the directory).
/tsm
/tsmd
!/tsmd/

# Plan files
/docs/plans/

# Git worktrees
/.worktrees/

# Go test/coverage output
*.test
*.out
coverage.txt
coverage.html
*.coverprofile

# Go workspace
go.work
go.work.sum

# Swift / SwiftPM build artifacts
.build/
.swiftpm/
DerivedData/
*.xcodeproj/

# macOS
.DS_Store

# Editor / IDE
.vscode/
.idea/
*.swp
*~

# Environment / local config
.env
.env.local
